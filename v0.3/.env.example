# Kopiere diese Datei nach `.env` und passe die Werte an.
# .env wird von docker-compose automatisch geladen.

# DB
DB_NAME=wettkampfDB
DB_USER=wettkampf
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme-root

# App
# Generiere einen guten SECRET_KEY z.B. mit:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=please-change-me

# Default-Admin (wird beim allerersten Start angelegt)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123
DEFAULT_ADMIN_MAIL=admin@example.com

# Auto-Logout nach X Sekunden Inaktivitaet (Default 3600 = 1 Stunde)
SESSION_MAX_AGE=3600

# Auf welchem Host-Port soll nginx lauschen
HTTP_PORT=8080
